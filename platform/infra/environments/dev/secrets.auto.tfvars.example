# Copy to secrets.auto.tfvars (gitignored) and fill in real values.
# These are account-specific / capacity-dependent and must NOT be committed.
#
#   cp secrets.auto.tfvars.example secrets.auto.tfvars
#   # then edit secrets.auto.tfvars with the real ODCR id
#
# Alternatively export TF_VAR_odcr_id=cr-xxxx in your shell / CI.

# On-Demand Capacity Reservation ID for the GPU node.
# Obtain via: aws ec2 create-capacity-reservation ... (see platform/README.md)
odcr_id = "cr-xxxxxxxxxxxxxxxxx"
